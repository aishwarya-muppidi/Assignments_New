  "item": [
    {
      "name": "create a duplicate repository for the authorized user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "//verify status code\r",
              "pm.test(\"Verify Status Code\", function(){\r",
              "    pm.expect(pm.response.code).to.eql(422);\r",
              "})\r",
              "//verify status message\r",
              "pm.test(\"Verify Status Message\", function(){\r",
              "    pm.expect(pm.response.status).to.include(\"Unprocessable Entity\")\r",
              "});\r",
              "//verify Response time\r",
              "pm.test(\"Verify Response time is less than 2000ms\",function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "})\r",
              "\r",
              "//verify Response Body\r",
              "pm.test(\"Verify Response Body\", function(){\r",
              "    let responseBody=pm.response.json();\r",
              "    pm.expect(responseBody.message).to.eql(\"Repository creation failed.\");\r",
              "    pm.expect(responseBody.errors[0].message).to.eql(\"name already exists on this account\")\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\"  :   \"JmeterRepo\"\r\n}",
